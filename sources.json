      "url_pattern": "https://www.python.org/ftp/python/{version}/Python-{version}.tgz"
    }
  },
  "gcc": {
    "version": "16.1.0",
    "purl": "pkg:generic/gcc",
    "source": {
      "url_pattern": "https://ftp.gnu.org/gnu/gcc/gcc-{version}/gcc-{version}.tar.xz"
    }
  },
  "zlib": {
    "version": "1.3.2",
    "purl": "pkg:generic/zlib",
