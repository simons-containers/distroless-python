      "url_pattern": "https://zlib.net/zlib-{version}.tar.gz"
    }
  },
  "openssl": {
    "version": "3.6.3",
    "purl": "pkg:generic/openssl",
    "source": {
      "url_pattern": "https://www.openssl.org/source/openssl-{version}.tar.gz"
    }
  },
  "readline": {
    "version": "8.3",
    "purl": "pkg:generic/readline",
    "source": {
      "url_pattern": "https://ftp.gnu.org/pub/gnu/readline/readline-{version}.tar.gz"
    }
  },
  "ncurses": {
    "version": "6.6",
    "purl": "pkg:generic/ncurses",
